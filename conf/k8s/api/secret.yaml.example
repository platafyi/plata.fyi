# DO NOT COMMIT THE REAL secret.yaml — only this example.
# Create the real one with kubectl or via CI/CD:
#
#   kubectl create secret generic api-secret \
#     --namespace platafyi \
#     --from-literal=DB_URL='postgres://platafyi:<password>@postgres:5432/platafyi?sslmode=disable' \
#     --from-literal=RESEND_API_KEY='re_...'
#
apiVersion: v1
kind: Secret
metadata:
  name: api-secret
  namespace: platafyi
type: Opaque
stringData:
  DB_URL: "postgres://platafyi:CHANGE_ME@postgres:5432/platafyi?sslmode=disable"
  RESEND_API_KEY: "re_CHANGE_ME"
