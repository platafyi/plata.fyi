# Database
DB_URL=postgres://platafyi:platafyi@localhost:5433/platafyi?sslmode=disable

# Resend API (email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# From address — omit to use onboarding@resend.dev (dev only, sends only to your Resend account email)
# For production set to: Plata.fyi <no-reply@plata.fyi>  (requires verified domain in Resend)
RESEND_FROM=
# Set to true in local dev to skip Resend and print magic links to the terminal
EMAIL_LOG=true

# Application
APP_URL=http://localhost:3000
API_URL=http://localhost:8080
PORT=8080

# Auth
# Secret used as HMAC key for additional token hardening (optional, any random string)
TOKEN_SECRET=change-me-in-production

# OpenCorporates (optional, increases rate limit)
OPENCORPORATES_API_KEY=
